# uClibc-ng locale tests
# Licensed under the LGPL v2.1, see the file COPYING.LIB in this tarball.

TESTS := bug-iconv-trans bug-usesetlocale collate-test dump-ctype \
	 gen-unicode-ctype show-ucs-data tst-ctype \
	 tst-digits tst-fmon tst-langinfo tst-leaks tst-mbswcs1 \
	 tst-mbswcs2 tst-mbswcs3 tst-mbswcs4 tst-mbswcs5 tst-mbswcs6 \
	 tst_nl_langinfo tst-numeric tst-rpmatch tst-setlocale \
	 tst-sscanf tst-strfmon1 tst-trans tst-wctype tst-xlocale1 \
	 tst-xlocale2 xfrm-test


# NOTE: For now disabled some tests that are known not build
TESTS_DISABLED := tst-ctype tst-fmon tst-leaks tst-rpmatch tst-strfmon1

# disable tests requiring UCLIBC_HAS_XLOCALE at the moment
TESTS_DISABLED += bug-usesetlocale tst-xlocale1 tst-xlocale2 xfrm-test tst-C-locale

# tst-wctype is entirely ja_JP-specific (it only queries the jhira, jkata,
# jdigit, jspace and jkanji classes). uClibc-ng has no locale-specific
# wctype classes, so every block errors out -- there is nothing else to run.
TESTS_DISABLED += tst-wctype

# tst-digits needs the synthetic "test7" locale, which glibc compiles with
# localedef. uClibc-ng has no localedef (locale data is baked in at library
# build time), so setlocale(LC_ALL,"test7") returns NULL and the test can
# never pass.
TESTS_DISABLED += tst-digits

# collate-test expects a random-seed argument plus a word list on stdin, and
# glibc judges it by diffing the sorted output against a reference. None of
# that (args, input list, reference .out) was ported here, so it just prints
# its usage and exits 1. strcoll/strxfrm themselves work fine.
TESTS_DISABLED += collate-test

# gen-unicode-ctype is not a test: it is glibc's build-time generator that
# turns a UnicodeData.txt file into an LC_CTYPE category. Run without its
# "UnicodeData.txt version" arguments it just prints usage and exits 1.
# uClibc-ng generates its ctype data with its own tools (gen_wctype), so
# this generator has no place in the test run.
TESTS_DISABLED += gen-unicode-ctype

# tst-sscanf only exercises fa_IR Persian digits via glibc's "%I" scanf flag
# (read the locale's outdigits instead of 0-9). uClibc-ng does not support
# the 'I' flag (see libc/stdio/_vfprintf.c), so every case fails with
# "nothing found" -- there is nothing else in the test.
TESTS_DISABLED += tst-sscanf

# bug-iconv-trans converts ISO-8859-1 to "ANSI_X3.4-1968//TRANSLIT" and
# expects the umlauts to be transliterated (AE, oe, ss, ...). uClibc-ng's
# iconv does an exact codeset-name match (no //TRANSLIT or //IGNORE suffix
# handling), does not know the IANA alias ANSI_X3.4-1968, and has no
# transliteration engine (see the translit TODOs in libc/misc/locale), so
# iconv_open already fails. The whole test is about //TRANSLIT.
TESTS_DISABLED += bug-iconv-trans

# tst-trans needs a locale-defined custom character map: a "test" wctrans
# (A->B, B->C) and custom outdigits used via the "%I" flag. uClibc-ng's
# wctrans() only knows the POSIX set, has no localedef to compile such a
# locale, and no "%I" support, so wctrans("test") returns 0 right away
# ("locale data files probably not loaded").
TESTS_DISABLED += tst-trans

DODIFF_rint     := 1

EXTRA_CFLAGS    := -D__USE_GNU -fno-builtin

OPTS_dump-ctype = C
OPTS_tst-ctype = < tst-ctype-de_DE.ISO-8859-1.in
OPTS_tst-langinfo = < tst-langinfo.input

EXTRA_DIRS := C
